<?xml version="1.0" encoding="utf-8"?>
<!-- EWDK/WDK KMDF driver project for pipakbd (ARM64). Build from an EWDK build env:
     msbuild pipakbd.vcxproj /p:Configuration=Release /p:Platform=ARM64 -->
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Release|ARM64">
      <Configuration>Release</Configuration>
      <Platform>ARM64</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <ProjectGuid>{8F3A1C42-9E21-4B7C-A0D5-1F2E3C4B5A60}</ProjectGuid>
    <TargetVersion>Windows10</TargetVersion>
    <DriverType>KMDF</DriverType>
    <RootNamespace>pipakbd</RootNamespace>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <PropertyGroup Label="Configuration">
    <ConfigurationType>Driver</ConfigurationType>
    <PlatformToolset>WindowsKernelModeDriver10.0</PlatformToolset>
    <UseDebugLibraries>false</UseDebugLibraries>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ItemDefinitionGroup>
    <ClCompile>
      <WppEnabled>false</WppEnabled>
      <PreprocessorDefinitions>_KERNEL_MODE;%(PreprocessorDefinitions)</PreprocessorDefinitions>
    </ClCompile>
    <Link>
      <!-- spbcx.lib (SpbCx I2C client) + vhfkm.lib (Virtual HID Framework, kernel).
           Both live on the WDK lib path provided by the WDK NuGet props; KMDF entry libs
           (WdfDriverEntry/WdfLdr) are added automatically by the KMDF toolset. -->
      <AdditionalDependencies>spbcx.lib;vhfkm.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Inf>
      <SpecifyArchitecture>true</SpecifyArchitecture>
      <Architecture>arm64</Architecture>
    </Inf>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClCompile Include="driver.c" />
    <ClCompile Include="device.c" />
    <ClCompile Include="spb.c" />
    <ClCompile Include="frame.c" />
    <ClCompile Include="vhf.c" />
  </ItemGroup>
  <ItemGroup>
    <ClInclude Include="pipakbd.h" />
    <ClInclude Include="report_descriptor.h" />
  </ItemGroup>
  <ItemGroup>
    <Inf Include="pipakbd.inf" />
  </ItemGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
</Project>
